{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "database: up",
      "type": "shell",
      "command": "docker compose up -d db",
      "problemMatcher": []
    },
    {
      "label": "backend: migrate",
      "type": "shell",
      "command": "python -m alembic upgrade head",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "dependsOn": ["database: up"],
      "problemMatcher": []
    },
    {
      "label": "backend: prepare debug",
      "dependsOrder": "sequence",
      "dependsOn": ["database: up", "backend: migrate"],
      "problemMatcher": []
    },
    {
      "label": "frontend: dev",
      "type": "shell",
      "command": "npm run dev -- --host 127.0.0.1",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      }
    }
  ]
}
