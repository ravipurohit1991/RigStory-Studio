{
  "name": "rigstory-frontend",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "generate:openapi": "python ../backend/scripts/export_openapi.py",
    "generate:client": "npm run generate:openapi && openapi-typescript src/api/generated/openapi.json -o src/api/generated/schema.d.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "license:report": "node scripts/license-report.mjs"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.68.0",
    "@tanstack/react-query": "^5.81.0",
    "lucide-react": "^0.468.0",
    "pixi.js": "^8.19.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@playwright/test": "^1.53.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.30.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.6.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  }
}
